{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "yet-another-player",
  "version": "0.1.0",
  "identifier": "com.bad.yet-another-player",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "yet-another-player",
        "width": 1800,
        "height": 1000,
        "decorations": false,
        "backgroundColor": "#01040c"
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; connect-src 'self' ipc: http://ipc.localhost http://127.0.0.1:* https://github.com https://*.githubusercontent.com; img-src 'self' data: asset: http://asset.localhost; media-src 'self' http://127.0.0.1:*",
      "assetProtocol": {
        "enable": true,
        "scope": []
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.png", "icons/icon.ico"]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDI0NzdBMkIzODIwODdFMUUKUldRZWZnaUNzNkozSkdUSG5CTjlDNWVrYlZ6SklIdFUvaDlhNTFxaXRDdm93dnN4TEFuMmtKMjcK",
      "endpoints": [
        "https://github.com/bad/yet-another-player/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
